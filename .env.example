################################################################
# Baljia-provisioned (the orchestrator writes these at scaffold)
################################################################

# Your isolated Neon Postgres (one project per user-app)
DATABASE_URL=postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/main?sslmode=require

# Baljia AI Gateway â€” routes LLM calls to platform key (free tier) or BYOK
# Your generated app uses the official SDKs pointed at this base URL.
AI_GATEWAY_URL=https://ai.baljia.app
AI_GATEWAY_TOKEN=blg_prod_<hex>

# App public URL (used by Better Auth for callback origins)
NEXT_PUBLIC_APP_URL=http://localhost:3000

################################################################
# Set by the user in Settings (or pasted before deploy)
################################################################

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Stripe â€” user pastes their own keys. Both are required for billing to work.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID=

# Optional: OAuth providers for Better Auth (add any/all)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
